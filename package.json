{
  "name": "safecalc",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "preflight": "node scripts/apk-preflight.js",
    "preflight:backend": "npm --prefix backend run preflight -- --strict",
    "preflight:all": "npm run preflight && npm run preflight:backend",
    "build:apk": "eas build --platform android --profile preview",
    "backend": "npm --prefix backend run dev",
    "backend:start": "npm --prefix backend run start"
  },
  "dependencies": {
    "axios": "^1.15.0",
    "crypto-js": "^4.2.0",
    "expo": "~54.0.33",
    "expo-background-fetch": "~14.0.9",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.8",
    "expo-local-authentication": "~17.0.8",
    "expo-secure-store": "~15.0.8",
    "expo-sensors": "~15.0.8",
    "expo-sms": "~14.0.8",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "expo-task-manager": "~14.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-keychain": "^10.0.0",
    "react-native-plaid-link-sdk": "^12.8.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@types/crypto-js": "^4.2.2",
    "@types/react": "~19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
