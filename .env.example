# Frontend runtime API base URL used by src/utils/demoBankApi.ts
# Use your backend LAN IP for local device testing, or public HTTPS URL for production.
# Example local: EXPO_PUBLIC_API_BASE_URL=http://192.168.1.23:4000
# Example cloud: EXPO_PUBLIC_API_BASE_URL=https://your-backend.example.com
EXPO_PUBLIC_API_BASE_URL=

# Supabase anon key for frontend (client-side) authentication
SUPABASE_ANON_KEY=your_supabase_anon_key_here
